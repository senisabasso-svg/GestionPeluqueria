# Base local SQLite (por defecto si omites DATABASE_URL): prisma/gestionBdPeluqueria.db
# Opcional, equivalente al valor por defecto:
# DATABASE_URL="file:./gestionBdPeluqueria.db"

# Cuando pases a PostgreSQL (Railway, etc.): cambia en prisma/schema.prisma
#   provider = "postgresql"
# y pon aquí la URL; luego: npx prisma generate && npx prisma db push
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

JWT_SECRET=cambiar-en-produccion
# CORS_ORIGIN=http://localhost:5173
