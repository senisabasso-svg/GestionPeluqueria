# PostgreSQL (Railway, etc.). Copie a .env y pegue su URL real.
# Desde fuera de Railway use la URL pública y añada ?sslmode=require
# DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DATABASE?sslmode=require"
#
# El backend ejecuta prisma db push al iniciar si DATABASE_URL está definida.

JWT_SECRET=cambiar-en-produccion
# CORS_ORIGIN=http://localhost:5173
